# Copy this file to .dev.vars and fill in your values
# .dev.vars is gitignored — never commit secrets

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_SESSION_SECRET=

# Cloudflare Turnstile (https://dash.cloudflare.com/turnstile)
# Public site key used by build.js; the default below is Cloudflare's local test key.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Secret key used by /api/contact. Use test key for local dev: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET=

# Contact form
CONTACT_EMAIL=
CONTACT_DESTINATION=
